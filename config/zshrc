# agent-sandbox zsh configuration
# Modeled after butterfly's raptor distrobox setup

##### zinit bootstrap
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -f $ZINIT_HOME/zinit.zsh ]]; then
    command mkdir -p "$(dirname "$ZINIT_HOME")" && command chmod g-rwX "$(dirname "$ZINIT_HOME")"
    command git clone https://github.com/zdharma-continuum/zinit "$ZINIT_HOME" && command git -C "$ZINIT_HOME" checkout 6c9ac1c4bc9bcaede64cb473759ac2c5b9187f98
fi

source "$ZINIT_HOME/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit
[[ ! -d "$ZPFX/bin" ]] && mkdir -p "$ZPFX/bin"

# Annexes
zinit light-mode for \
    ver"e1f9b7274f4df3d15c92d46c49f52ce58f947766" zdharma-continuum/zinit-annex-as-monitor \
    ver"89739902eafacb3c9c389f896177fb25e8a95f38" zdharma-continuum/zinit-annex-bin-gem-node \
    ver"ddb174be3aa308e7428691216f09aa69e8e2f94f" zdharma-continuum/zinit-annex-patch-dl \
    ver"c747bf9c5a2b85347238fa433c0addcfc7745c6e" zdharma-continuum/zinit-annex-rust

##### PATH & early env
export ASDF_DATA_DIR="${ASDF_DATA_DIR:-$HOME/.asdf}"
export NPM_CONFIG_PREFIX="${NPM_CONFIG_PREFIX:-$HOME/.npm-global}"

# PATH priority: user-local overrides > cargo user > asdf shims > npm global > go > system cargo
path=("$HOME/.local/bin" "$HOME/.cargo/bin" "$ASDF_DATA_DIR/shims" "$NPM_CONFIG_PREFIX/bin" "$HOME/go/bin" $path)

# asdf + starship are installed at build time in /usr/local/bin
eval "$(starship init zsh)"
if [[ -d "$ASDF_DATA_DIR" ]]; then
    fpath=("$ASDF_DATA_DIR/completions" $fpath)
fi

##### dircolors / LS_COLORS
zinit ice ver"810ce8cac886ac50e75d84fb438b549a1f9478ee" atclone'dircolors -b LS_COLORS > clrs.zsh' atpull'%atclone' pick"clrs.zsh" nocompile'!' \
          atload'zstyle ":completion:*" list-colors "${(s.:.)LS_COLORS}"'
zinit light trapd00r/LS_COLORS

##### direnv
# direnv is installed at build time in /usr/local/bin
eval "$(direnv hook zsh)"

##### Navigation tools + interactive config
zinit ice ver"ac011dc5261e66944a2e517f2b60057529e8f45a" wait"1" lucid atload'!source ~/.zsh/interactive.zsh'
zinit load psprint/zsh-navigation-tools

##### Core line editing + completions (deferred)
zinit lucid wait for \
    ver"3d574ccf48804b10dca52625df13da5edae7f553" zdharma-continuum/fast-syntax-highlighting \
    ver"ed67fbb8ee9ec00abfaecdc3dcfc330202ede323" blockf zsh-users/zsh-completions \
    ver"85919cd1ffa7d2d5412f6d3fe437ebdbeeec4fc5" atload"!_zsh_autosuggest_start" zsh-users/zsh-autosuggestions

##### Completion init — after all fpath edits
ZINIT[ZCOMPDUMP_PATH]="${HOME}/.zcompdump-${HOST}"
ZINIT[COMPINIT_OPTS]=-C
zicompinit
zicdreplay

##### Shell options
setopt cbases extendedglob nobgnice

##### Aliases
alias ls='eza -lah --color=auto --icons=auto --group-directories-first'
alias ll='eza -lah --color=auto --icons=auto --group-directories-first'
alias la='eza -ah --color=auto --icons=auto --group-directories-first'
alias lt='eza --tree --color=auto --icons=auto --group-directories-first'
alias cat='bat --paging=never'
alias vim='nvim'
alias vi='nvim'
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias glog='git log --oneline --graph --decorate'
alias py='python3'
alias pip='uv pip'

##### JAVA_HOME (let asdf's java plugin provide the canonical value)
if command -v asdf &>/dev/null && asdf current java &>/dev/null 2>&1; then
    export JAVA_HOME="$(asdf env javac 2>/dev/null | grep JAVA_HOME | cut -d= -f2)"
fi
